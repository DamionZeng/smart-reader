# Agnes AI API key for document parsing.
# Get yours at https://platform.agnes-ai.com
AGNES_API_KEY="YOUR_AGNES_API_KEY"

# PostgreSQL connection string.
# - For the local Docker database started by `docker compose up -d`, use:
#     DATABASE_URL="postgres://smartreader:smartreader@localhost:5432/smartreader"
# - For Neon (or other cloud providers), paste their connection string here.
#   The driver is auto-selected based on the hostname (see src/lib/db.ts):
#   *.neon.tech / *.neon.com / *.neon.build  -> Neon HTTP driver
#   everything else                          -> node-postgres (pg) pool
DATABASE_URL="postgres://smartreader:smartreader@localhost:5432/smartreader"

# Better Auth secret used to encrypt tokens and sessions.
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="YOUR_BETTER_AUTH_SECRET"

# Google OAuth credentials.
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Public base URL of the app (used by the frontend auth client).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Base URL of the app (used by the backend auth server and OAuth callbacks).
APP_URL="http://localhost:3000"

# Cloudflare R2 storage (S3-compatible). Used by the Tier 2 image pipeline
# to store user-uploaded source images. The public URL is the CDN edge that
# browsers will hit directly when rendering thumbnails / attached images.
R2_ENDPOINT_URL="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="YOUR_R2_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="YOUR_R2_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="YOUR_R2_BUCKET_NAME"
R2_PUBLIC_URL="https://pub-XXXXX.r2.dev"

# Resend transactional email — used to deliver 6-digit sign-up verification
# codes. Get an API key at https://resend.com/api-keys.
# RESEND_FROM must be a verified sender domain on your Resend account
# (or the default onboarding@resend.dev for testing).
RESEND_API_KEY="re_YOUR_API_KEY"
RESEND_FROM="onboarding@resend.dev"
